<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER_LEFT" minHeight="72" spacing="8" HBox.hgrow="ALWAYS" styleClass="person-card">
        <padding>
            <Insets top="12" right="12" bottom="12" left="10"/>
        </padding>
        <HBox alignment="TOP_LEFT" spacing="7">
            <Label fx:id="id" styleClass="card-index">
                <minWidth>
                    <Region fx:constant="USE_PREF_SIZE"/>
                </minWidth>
            </Label>
            <VBox alignment="CENTER_LEFT" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="name" text="\$first" styleClass="card-name"/>
                <TextFlow>
                    <Text styleClass="card-secondary-label" text="NUS Matric: "/>
                    <Text fx:id="nusMatricValue" styleClass="card-secondary" text="\$nusMatric"/>
                </TextFlow>
            </VBox>
            <Label fx:id="role" styleClass="card-role-badge" text="\$role"/>
            <Label fx:id="tutorialGroup" styleClass="card-tutorial-badge" text="\$tutorialGroup"/>
        </HBox>
    </VBox>
</HBox>
